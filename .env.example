# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Start with: docker compose up -d
MONGODB_URI=mongodb://localhost:27017/cryptoshield

# ─── Algorand ─────────────────────────────────────────────────────────────────
ALGOD_SERVER=https://testnet-api.algonode.cloud
INDEXER_SERVER=https://testnet-idx.algonode.cloud

# App ID — set this after deploying the smart contract (python contracts/compile.py then algokit deploy)
ALGORAND_APP_ID=0

# Admin wallet mnemonic (25 words) — used to submit/verify on-chain
# Get a testnet wallet from https://bank.testnet.algorand.network/
ADMIN_MNEMONIC=word1 word2 word3 ... word25
